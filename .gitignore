# Python cache files
**/__pycache__/
*.pyc
*.pyo
GIT Tim.txt
D0FUS_OUTPUTS/

# Outputs (keep structure only)
D0FUS_OUTPUTS/genetic/*
D0FUS_OUTPUTS/run/*
D0FUS_OUTPUTS/scan/*
D0FUS_OUTPUTS/uncertainty/*
D0FUS_OUTPUTS/popcon/*
!D0FUS_OUTPUTS/genetic/.gitkeep
!D0FUS_OUTPUTS/run/.gitkeep
!D0FUS_OUTPUTS/scan/.gitkeep
!D0FUS_OUTPUTS/uncertainty/.gitkeep
!D0FUS_OUTPUTS/popcon/.gitkeep

# Personal inputs
D0FUS_INPUTS/*_perso*
D0FUS_INPUTS/*_paper*

# Build artifacts
dist/
build/
*.egg-info/input/
*.egg-info/
# Ignore working/personal input decks in D0FUS_INPUTS by default, but keep the
# canonical numbered ITER example decks (1..5) under version control so the
# four execution modes (run / scan / genetic / uncertainty / popcon) ship with
# a reproducible reference input.
D0FUS_INPUTS/*.txt
!D0FUS_INPUTS/1_run_ITER.txt
!D0FUS_INPUTS/2_scan_ITER.txt
!D0FUS_INPUTS/3_genetic_ITER.txt
!D0FUS_INPUTS/4_uncertainty_ITER.txt
!D0FUS_INPUTS/5_popcon_ITER.txt
desktop.ini

# Local inputs (not tracked)
D0FUS_INPUTS/EU DEMO/
D0FUS_INPUTS/Manuscript/
D0FUS_INPUTS/Papier meca/
D0FUS_INPUTS/SF Plant/
D0FUS_INPUTS/VNS/

# Personal notes
GIT_cheat_sheet.txt
Pypi_Wheel_tuto.txt

# Local publication script
publish_d0fus.sh
*.log
D0FUS_figures_catalog/